<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibrarySystem.UI.Views.ChangePasswordPage"
             Title="🔑 Şifre Değiştir">
    <VerticalStackLayout Padding="30" Spacing="14" VerticalOptions="Center">
        <Entry x:Name="OldPasswordEntry" Placeholder="Mevcut şifre" IsPassword="True" />
        <Entry x:Name="NewPasswordEntry" Placeholder="Yeni şifre (min. 6 karakter)" IsPassword="True" />
        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Yeni şifre tekrar" IsPassword="True" />
        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" />
        <Button Text="✅ Şifreyi Güncelle" BackgroundColor="#1565C0" TextColor="White"
                CornerRadius="10" HeightRequest="50" Clicked="Change_Clicked" />
    </VerticalStackLayout>
</ContentPage>