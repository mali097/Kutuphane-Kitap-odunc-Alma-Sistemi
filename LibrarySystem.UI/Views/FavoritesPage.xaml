<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibrarySystem.UI.Views.FavoritesPage"
             Title="❤️ Favorilerim">
    <CollectionView x:Name="FavoritesList" Margin="10"
                    EmptyView="Henüz favori kitap eklemediniz. 🤍">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="0,5" Padding="14" BackgroundColor="#FCE4EC"
                        StrokeShape="RoundRectangle 12" Stroke="#F48FB1">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding BookTitle}" FontAttributes="Bold"
                                   TextColor="#880E4F" FontSize="15" />
                            <Label Text="{Binding BookAuthor, StringFormat='✍️ {0}'}"
                                   TextColor="#AD1457" FontSize="13" />
                            <Label Text="{Binding BookCategory, StringFormat='📂 {0}'}"
                                   TextColor="Gray" FontSize="12" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="🗑️"
                                BackgroundColor="Transparent" FontSize="20"
                                CommandParameter="{Binding .}"
                                Clicked="RemoveFav_Clicked" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>