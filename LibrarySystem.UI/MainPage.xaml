<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibrarySystem.UI.MainPage">
    <Grid Padding="16" ColumnDefinitions="2.3*,1*" ColumnSpacing="14">

        <VerticalStackLayout Grid.Column="0" Spacing="12">
            <Label Text="📚 Kütüphane Sistemi"
                   FontSize="28"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="UserIdEntry"
                       Placeholder="Ödünç alan kullanıcı ID"
                       Keyboard="Numeric"
                       HorizontalOptions="FillAndExpand" />
                <Button Text="Listeyi Yenile"
                        Clicked="OnRefreshClicked" />
            </HorizontalStackLayout>

            <CollectionView x:Name="BooksList"
                            SelectionMode="None"
                            VerticalOptions="FillAndExpand">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="4" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Label Text="{Binding AuthorLine}"
                                       FontSize="12"
                                       TextColor="Gray" />
                                <Label Text="{Binding DetailLine}"
                                       FontSize="12"
                                       TextColor="Gray" />
                                <Label Text="{Binding AvailabilityText}"
                                       FontAttributes="Bold"
                                       TextColor="{Binding AvailabilityColor}" />
                                <Button Text="Ödünç Al"
                                        CommandParameter="{Binding Id}"
                                        IsEnabled="{Binding IsAvailable}"
                                        Clicked="OnBorrowBookClicked" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Border Grid.Column="1"
                Padding="10"
                StrokeShape="RoundRectangle 10"
                Background="#F7F6FF">
            <VerticalStackLayout Spacing="8">
                <Label Text="📝 Haftalık Kitap Önerileri"
                       FontAttributes="Bold"
                       FontSize="16" />
                <CollectionView x:Name="WeeklyRecommendationsList"
                                SelectionMode="None"
                                VerticalOptions="FillAndExpand">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="3" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding BookTitle}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding AuthorName}"
                                           FontSize="12"
                                           TextColor="Gray" />
                                    <Label Text="{Binding Idea}"
                                           FontSize="12" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>